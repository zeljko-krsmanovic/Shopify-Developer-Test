{% comment %}
  ------------------------------------------------------------
  Custom Homepage — Reviews
  Customer testimonials as reorderable blocks. Each review has a
  reviewer name, review text, a 1-5 star rating, an optional
  reviewer photo, and an optional linked product.
  ------------------------------------------------------------
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign is_hidden = false
  unless s.show_section
    assign is_hidden = true
  endunless
-%}

{%- if s.show_section or request.design_mode -%}
  <section
    class="ch-section ch-reviews{% if is_hidden %} ch-is-hidden{% endif %}"
    style="
      padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
      {% if s.background_color != blank %}background: {{ s.background_color }};{% endif %}
      {% if s.text_color != blank %}color: {{ s.text_color }};{% endif %}
      --ch-page-width: {% if s.section_width == 'full-width' %}100%{% else %}1200px{% endif %};
      --ch-cols: {{ s.columns }};
      --ch-gap: {{ s.gap }}px;
    "
  >
    <div class="ch-container">
      {%- if s.heading != blank or s.subheading != blank -%}
        <div class="ch-section__header">
          {%- if s.heading != blank -%}<h2 class="ch-section__title">{{ s.heading }}</h2>{%- endif -%}
          {%- if s.subheading != blank -%}<div class="ch-section__subtitle">{{ s.subheading }}</div>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="ch-grid">
        {%- for block in section.blocks -%}
          {%- liquid
            assign rating = block.settings.rating | round
            assign linked_product = block.settings.product
            assign review_alt = block.settings.author | escape
          -%}
          <div class="ch-review" {{ block.shopify_attributes }}>
            {%- if rating > 0 -%}
              <div class="ch-review__stars" aria-label="{{ rating }} out of 5 stars">
                {%- for i in (1..5) -%}
                  {%- if i <= rating -%}
                    <span class="ch-star" aria-hidden="true">&#9733;</span>
                  {%- else -%}
                    <span class="ch-star ch-star--empty" aria-hidden="true">&#9733;</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if block.settings.review != blank -%}
              <div class="ch-review__text">{{ block.settings.review }}</div>
            {%- endif -%}

            <div class="ch-review__footer">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 96
                  | image_tag:
                    widths: '48, 96',
                    sizes: '48px',
                    alt: review_alt,
                    class: 'ch-review__avatar',
                    loading: 'lazy'
                }}
              {%- endif -%}
              <div>
                {%- if block.settings.author != blank -%}
                  <div class="ch-review__author">{{ block.settings.author }}</div>
                {%- endif -%}
                {%- if linked_product != blank -%}
                  <div class="ch-review__product">
                    <a href="{{ linked_product.url }}">on {{ linked_product.title }}</a>
                  </div>
                {%- elsif block.settings.role != blank -%}
                  <div class="ch-review__product">{{ block.settings.role }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- else -%}
          {%- if request.design_mode -%}
            <p>Add a review block to get started.</p>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Custom Reviews",
  "tag": "section",
  "class": "ch-reviews-wrapper",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between reviews",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Reviewer name",
          "default": "Jane D."
        },
        {
          "type": "richtext",
          "id": "review",
          "label": "Review text",
          "default": "<p>Absolutely love it — exactly as described and the quality is fantastic. Will be ordering again!</p>"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Reviewer photo (optional)"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Reviewer role / label (optional)",
          "info": "Shown only when no linked product is set, e.g. \"Verified buyer\"."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Reviews",
      "category": "Custom homepage",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author": "Jane D.",
            "rating": 5,
            "role": "Verified buyer"
          }
        },
        {
          "type": "review",
          "settings": {
            "author": "Marcus T.",
            "review": "<p>Great value and fast shipping. The fit is perfect and it feels premium.</p>",
            "rating": 5,
            "role": "Verified buyer"
          }
        },
        {
          "type": "review",
          "settings": {
            "author": "Priya S.",
            "review": "<p>Customer service was super helpful and the product exceeded my expectations.</p>",
            "rating": 4,
            "role": "Verified buyer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
