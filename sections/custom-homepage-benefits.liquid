{% comment %}
  ------------------------------------------------------------
  Custom Homepage — Benefits
  A horizontal bar of 2-4 selling points. Each item is a block
  (drag to reorder / add / remove in the Theme Editor) with an
  icon or image, title, short text, and an optional link.
  ------------------------------------------------------------
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign is_hidden = false
  unless s.show_section
    assign is_hidden = true
  endunless
-%}

{%- if s.show_section or request.design_mode -%}
  <section
    class="ch-section ch-benefits{% if is_hidden %} ch-is-hidden{% endif %}"
    style="
      padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
      {% if s.background_color != blank %}background: {{ s.background_color }};{% endif %}
      {% if s.text_color != blank %}color: {{ s.text_color }};{% endif %}
      --ch-page-width: {% if s.section_width == 'full-width' %}100%{% else %}1200px{% endif %};
      --ch-cols: {{ s.columns }};
      --ch-gap: {{ s.gap }}px;
      --ch-item-align: {% if s.alignment == 'left' %}flex-start{% else %}center{% endif %};
      --ch-item-align-text: {{ s.alignment }};
    "
  >
    <div class="ch-container">
      {%- if s.heading != blank or s.subheading != blank -%}
        <div class="ch-section__header">
          {%- if s.heading != blank -%}<h2 class="ch-section__title">{{ s.heading }}</h2>{%- endif -%}
          {%- if s.subheading != blank -%}<div class="ch-section__subtitle">{{ s.subheading }}</div>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="ch-grid">
        {%- for block in section.blocks -%}
          {%- assign icon_alt = block.settings.title | escape -%}
          <div class="ch-benefits__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              {{
                block.settings.icon
                | image_url: width: 160
                | image_tag:
                  widths: '56, 112, 160',
                  sizes: '56px',
                  alt: icon_alt,
                  class: 'ch-benefits__icon',
                  loading: 'lazy'
              }}
            {%- else -%}
              <span class="ch-benefits__icon-fallback" aria-hidden="true">★</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="ch-benefits__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="ch-benefits__text">{{ block.settings.text }}</p>
            {%- endif -%}

            {%- if block.settings.link != blank and block.settings.link_label != blank -%}
              <a class="ch-benefits__link" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- comment -%} Visible only in the editor when no blocks exist yet. {%- endcomment -%}
          {%- if request.design_mode -%}
            <p>Add a benefit block to get started.</p>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Custom Benefits",
  "tag": "section",
  "class": "ch-benefits-wrapper",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why shop with us"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Item alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon / image",
          "info": "Square images (e.g. 120x120) work best."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Short supporting sentence about this benefit."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn more"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Benefits",
      "category": "Custom homepage",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Free shipping",
            "text": "On all orders over $50, delivered to your door."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Easy returns",
            "text": "30-day hassle-free returns, no questions asked."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Secure checkout",
            "text": "Your payment details are always protected."
          }
        }
      ]
    }
  ]
}
{% endschema %}
