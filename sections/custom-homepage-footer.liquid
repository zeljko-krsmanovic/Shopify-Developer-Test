{% comment %}
  ------------------------------------------------------------
  Custom Homepage — Footer
  Fully editable footer: about text + logo, one or more link
  groups (each picks a navigation menu), contact details, social
  links, and a copyright line.

  NOTE: This theme already renders a site-wide footer via
  sections/footer-group.json. Use THIS section by either:
    (a) adding it to a template (e.g. the homepage), or
    (b) swapping it into footer-group.json to replace the
        default footer everywhere.
  See CUSTOM-HOMEPAGE-NOTES.md for details.
  ------------------------------------------------------------
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign is_hidden = false
  unless s.show_section
    assign is_hidden = true
  endunless

  # Work out how many columns sit next to the "about" column so the
  # grid can size itself: one per link group, plus one for contact.
  assign group_count = 0
  for block in section.blocks
    if block.type == 'link_group'
      assign group_count = group_count | plus: 1
    endif
  endfor

  assign has_contact = false
  if s.address != blank or s.phone != blank or s.email != blank
    assign has_contact = true
  endif

  assign footer_cols = group_count
  if has_contact
    assign footer_cols = footer_cols | plus: 1
  endif
  if footer_cols < 1
    assign footer_cols = 1
  endif

  assign logo_alt = shop.name | escape
-%}

{%- if s.show_section or request.design_mode -%}
  <section
    class="ch-section ch-footer{% if is_hidden %} ch-is-hidden{% endif %}"
    style="
      padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
      {% if s.background_color != blank %}background: {{ s.background_color }};{% endif %}
      {% if s.text_color != blank %}color: {{ s.text_color }};{% endif %}
      --ch-page-width: {% if s.section_width == 'full-width' %}100%{% else %}1200px{% endif %};
      --ch-cols: {{ footer_cols }};
    "
  >
    <div class="ch-container">
      <div class="ch-footer__top">
        {%- comment -%} About column {%- endcomment -%}
        <div class="ch-footer__about">
          {%- if s.logo != blank -%}
            {{
              s.logo
              | image_url: width: 320
              | image_tag:
                widths: '160, 320',
                sizes: '160px',
                alt: logo_alt,
                class: 'ch-footer__about-logo',
                loading: 'lazy'
            }}
          {%- endif -%}
          {%- if s.about_text != blank -%}
            <div class="ch-footer__about-text">{{ s.about_text }}</div>
          {%- endif -%}

          {%- comment -%} Social links (social blocks) {%- endcomment -%}
          {%- assign has_social = false -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'social' and block.settings.link != blank -%}{%- assign has_social = true -%}{%- endif -%}
          {%- endfor -%}
          {%- if has_social -%}
            <div class="ch-footer__social">
              {%- for block in section.blocks -%}
                {%- if block.type == 'social' and block.settings.link != blank -%}
                  {%- assign social_alt = block.settings.label | escape -%}
                  <a href="{{ block.settings.link }}" {{ block.shopify_attributes }}
                    {% if block.settings.label != blank %}aria-label="{{ block.settings.label | escape }}"{% endif %}
                    target="_blank" rel="noopener">
                    {%- if block.settings.icon != blank -%}
                      {{
                        block.settings.icon
                        | image_url: width: 48
                        | image_tag: widths: '24, 48', sizes: '24px', alt: social_alt, loading: 'lazy'
                      }}
                    {%- else -%}
                      <span class="ch-footer__social-text">{{ block.settings.label | default: 'Link' }}</span>
                    {%- endif -%}
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Link groups + contact column {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_group' -%}
            <div class="ch-footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="ch-footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
                <ul class="ch-footer__menu">
                  {%- for link in block.settings.menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- elsif request.design_mode -%}
                <p>Select a menu for this link group.</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if has_contact -%}
          <div class="ch-footer__col">
            {%- if s.contact_heading != blank -%}
              <h3 class="ch-footer__heading">{{ s.contact_heading }}</h3>
            {%- endif -%}
            <ul class="ch-footer__contact">
              {%- if s.address != blank -%}<li>{{ s.address }}</li>{%- endif -%}
              {%- if s.phone != blank -%}<li><a href="tel:{{ s.phone | strip_html | replace: ' ', '' }}">{{ s.phone }}</a></li>{%- endif -%}
              {%- if s.email != blank -%}<li><a href="mailto:{{ s.email }}">{{ s.email }}</a></li>{%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      <div class="ch-footer__bottom">
        <div class="ch-footer__copyright">
          {%- if s.copyright != blank -%}
            {{ s.copyright }}
          {%- else -%}
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
          {%- endif -%}
        </div>
        {%- if s.show_payment_note and s.payment_note != blank -%}
          <div class="ch-footer__payment-note">{{ s.payment_note }}</div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "class": "ch-footer-wrapper",
  "max_blocks": 6,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "About"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (optional)"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "About text",
      "default": "<p>Thoughtfully made products for everyday life. Crafted to last, designed to delight.</p>"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "info": "Leave blank to auto-generate from your store name and the current year."
    },
    {
      "type": "checkbox",
      "id": "show_payment_note",
      "label": "Show secondary note",
      "default": false
    },
    {
      "type": "text",
      "id": "payment_note",
      "label": "Secondary note",
      "default": "Secure payments"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "link_group",
      "name": "Link group",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer",
          "info": "Pick a navigation menu (Online Store → Navigation)."
        }
      ]
    },
    {
      "type": "social",
      "name": "Social link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Instagram"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)",
          "info": "If left blank, the label text is shown instead."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "category": "Custom homepage",
      "blocks": [
        {
          "type": "link_group",
          "settings": { "heading": "Shop" }
        },
        {
          "type": "link_group",
          "settings": { "heading": "Company" }
        },
        { "type": "social", "settings": { "label": "Instagram" } },
        { "type": "social", "settings": { "label": "Facebook" } }
      ]
    }
  ]
}
{% endschema %}
