{% comment %}
  ------------------------------------------------------------
  Custom Homepage — Collections
  A collection showcase built from reorderable "Collection card"
  blocks. Each card can either:
    1. Reference a real Shopify collection (image, title,
       description and link auto-fill from it), OR
    2. Be a fully manual card — set your own image, title,
       description and a custom button link.
  Any per-card field left blank falls back to the picked
  collection's value, so a card can mix both modes. This is what
  lets every card point to the correct, merchant-chosen link.
  Layout can be a responsive grid or a CSS-only swipe carousel
  (no JavaScript required), with an optional section CTA.
  ------------------------------------------------------------
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign is_hidden = false
  unless s.show_section
    assign is_hidden = true
  endunless
-%}

{%- if s.show_section or request.design_mode -%}
  <section
    class="ch-section ch-collections ch-collections--{{ s.layout }}{% if is_hidden %} ch-is-hidden{% endif %}"
    style="
      padding-block: {{ s.padding_top }}px {{ s.padding_bottom }}px;
      {% if s.background_color != blank %}background: {{ s.background_color }};{% endif %}
      {% if s.text_color != blank %}color: {{ s.text_color }};{% endif %}
      --ch-page-width: {% if s.section_width == 'full-width' %}100%{% else %}1200px{% endif %};
      --ch-cols: {{ s.columns }};
      --ch-gap: {{ s.gap }}px;
      --ch-accent: {{ s.button_color | default: '#1a1a1a' }};
      --ch-accent-text: {{ s.button_text_color | default: '#ffffff' }};
    "
  >
    <div class="ch-container">
      {%- if s.heading != blank or s.subheading != blank -%}
        <div class="ch-section__header">
          {%- if s.heading != blank -%}<h2 class="ch-section__title">{{ s.heading }}</h2>{%- endif -%}
          {%- if s.subheading != blank -%}<div class="ch-section__subtitle">{{ s.subheading }}</div>{%- endif -%}
        </div>
      {%- endif -%}

      <div class="ch-grid">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign b = block.settings
              assign coll = b.collection

              # Resolve each field: per-card override first, then the
              # picked collection, then a sensible fallback.
              assign card_title = b.title
              if card_title == blank
                assign card_title = coll.title
              endif

              assign card_link = b.link
              if card_link == blank
                assign card_link = coll.url
              endif

              assign card_image = b.image
              if card_image == blank
                assign card_image = coll.image
              endif
              if card_image == blank and coll != blank
                assign card_image = coll.products.first.featured_image
              endif

              assign card_desc = b.description
              if card_desc == blank
                assign card_desc = coll.description
              endif

              assign card_label = b.button_label | default: s.button_label | default: 'Shop'
              assign card_alt = card_title | escape
            -%}
            <div class="ch-card" {{ block.shopify_attributes }}>
              {%- if card_link != blank -%}
                <a class="ch-card__media ch-img" href="{{ card_link }}">
              {%- else -%}
                <div class="ch-card__media ch-img">
              {%- endif -%}
                {%- if card_image != blank -%}
                  {{
                    card_image
                    | image_url: width: 800
                    | image_tag:
                      widths: '300, 500, 700, 800',
                      sizes: '(max-width: 749px) 100vw, 33vw',
                      alt: card_alt,
                      loading: 'lazy'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'ch-img' }}
                {%- endif -%}
              {%- if card_link != blank -%}</a>{%- else -%}</div>{%- endif -%}

              {%- if card_title != blank -%}
                {%- if card_link != blank -%}
                  <a class="ch-card__title" href="{{ card_link }}">{{ card_title }}</a>
                {%- else -%}
                  <span class="ch-card__title">{{ card_title }}</span>
                {%- endif -%}
              {%- endif -%}

              {%- if s.show_description and card_desc != blank -%}
                <p class="ch-card__desc">
                  {{ card_desc | strip_html | truncatewords: 18 }}
                </p>
              {%- endif -%}

              {%- if card_link != blank -%}
                <div class="ch-card__footer">
                  <a class="ch-btn ch-btn--primary" href="{{ card_link }}">{{ card_label }}</a>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- elsif request.design_mode -%}
          {%- comment -%} Editor-only placeholders so the section isn't empty before any cards are added. {%- endcomment -%}
          {%- assign placeholder_count = s.columns -%}
          {%- for i in (1..placeholder_count) -%}
            <div class="ch-card">
              <div class="ch-card__media ch-img">{{ 'collection-' | append: i | placeholder_svg_tag: 'ch-img' }}</div>
              <span class="ch-card__title">Example collection</span>
              {%- if s.show_description -%}<p class="ch-card__desc">A short description of this collection.</p>{%- endif -%}
              <div class="ch-card__footer">
                <span class="ch-btn ch-btn--primary">{{ s.button_label | default: 'Shop' }}</span>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if s.cta_label != blank and s.cta_link != blank -%}
        <div class="ch-collections__cta">
          <a class="ch-btn ch-btn--secondary" href="{{ s.cta_link }}">{{ s.cta_label }}</a>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Custom Collections",
  "tag": "section",
  "class": "ch-collections-wrapper",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "paragraph",
      "content": "Add a \"Collection card\" block for each card. Pick a Shopify collection to auto-fill it, or fill the fields manually and set a custom button link."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Default button label",
      "default": "Shop",
      "info": "Used when a card doesn't set its own button label."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel (swipe)" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Cards per row (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "info": "Optional button shown below the cards (e.g. \"View all collections\")."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_background",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Pick a collection to auto-fill the image, title, description and link. Leave empty to build a fully manual card."
        },
        {
          "type": "header",
          "content": "Overrides (optional)"
        },
        {
          "type": "paragraph",
          "content": "Anything you set here overrides the collection above. Leave blank to use the collection's own value."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button / card link",
          "info": "Set a custom link for this card. Defaults to the picked collection's page."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "info": "Defaults to the section's default button label."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collections",
      "category": "Custom homepage",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}
